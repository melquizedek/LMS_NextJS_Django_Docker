# Global ignore rules for when building from root context
**/.DS_Store
**/.git
**/.gitignore
**/.idea
**/.vscode
**/*.dbmdl
**/*.jfm
**/*.jfm
**/bin
**/obj

# Specific service paths to ignore if built from root
backend/__pycache__
backend/.venv
backend/media
backend/static
backend/staticfiles
backend/db.sqlite3

frontend/node_modules
frontend/.next
frontend/out
frontend/build
frontend/dist

# Docker related
Dockerfile*
docker-compose*
compose.y*ml
.dockerignore

# Root level
README.md
LICENSE
node_modules